<script>
    document.addEventListener('DOMContentLoaded', () => {
        const resList = document.getElementById('reservation-list');
        if (resList) {
            resList.addEventListener('click', (e) => {
                const row = e.target.closest('.clickable-row');
                if (row) {
                    window.location.href = `/staff/guest-bookings/${row.dataset.id}`;
                }
            });
        }
    });

    function filterGuests(query) {
        const rows = document.querySelectorAll('#reservation-list .clickable-row');
        const q = query.toLowerCase().trim();
        let visibleCount = 0;

        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            const match = text.includes(q);
            row.style.display = match ? '' : 'none';
            if (match) visibleCount++;
        });

        document.getElementById('no-results').style.display = visibleCount === 0 ? 'block' : 'none';
    }
</script>


<main class="fd-main">
    <header class="content-header">
        <h2 id="tab-title" class="header-font">View Reservations</h2>
        <div class="staff-info">Staff Access</div>
    </header>

    <div id="reservations" class="tab-pane">
        <div class="fd-table-card">
            <div class="search-bar-wrapper">
                <input
                    type="text"
                    id="guest-search"
                    class="guest-search-input"
                    placeholder="Search by name, email, or phone..."
                    oninput="filterGuests(this.value)"
                >
            </div>
            <p id="no-results" style="display:none; color:#888; margin: 12px 0; font-family:'Montserrat';">No guests match your search.</p>
            <table class="fd-data-table">
                <thead>
                    <tr>
                        <th>Guest Name</th>
                        <th>Reservations</th>
                        <th>Last Check-In</th>
                        <th>Last Check-Out</th>
                        <th>Email</th>
                        <th>Phone</th>
                    </tr>
                </thead>
                <tbody id="reservation-list">
                    {{#each guests}}
                    <tr class="clickable-row" data-guest="{{this.firstName}} {{this.lastName}}" data-id="{{this.id}}">
                        <td class="guest-name">{{this.firstName}} {{this.lastName}}</td>
                        <td>{{this.totalBookings}}</td>
                        <td>{{this.displayIn}}</td>
                        <td>{{this.displayOut}}</td>
                        <td>{{this.email}}</td>
                        <td>{{this.contact}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</main>