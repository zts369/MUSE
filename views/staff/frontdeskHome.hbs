<script>
    document.addEventListener('DOMContentLoaded', () => {
        const resList = document.getElementById('reservation-list');
        if (resList) {
            resList.addEventListener('click', (e) => {
                const row = e.target.closest('.clickable-row');
                if (row) {
                    // Redirect to a dynamic route using the Guest's ID
                    // Assuming you add 'data-id' to your <tr>
                    const guestId = row.dataset.id;
                    window.location.href = `/staff/guest-bookings/${row.dataset.id}`;
                }
            });
        }
    });
</script>

<title>Front Desk | Hotel Transylvania</title>

<main class="fd-main">
    <header class="content-header">
        <h2 id="tab-title" class="header-font">View Reservations</h2>
        <div class="staff-info">Staff Access</div>
    </header>

    <div id="reservations" class="tab-pane">
        <div class="fd-table-card">
            <table class="fd-data-table">
                <thead>
                    <tr>
                        <th>Guest Name</th>
                        <th>Reservations</th>
                        <th>Check-In</th>
                        <th>Check-Out</th>
                        <th>Email</th>
                        <th>Phone</th>
                    </tr>
                </thead>
                <tbody id="reservation-list">
                    {{#each guests}}
                    <tr class="clickable-row" data-guest="{{this.firstName}} {{this.lastName}}" data-id="{{this.id}}">
                        <td class="guest-name">{{this.firstName}} {{this.lastName}}</td>
                        
                        {{!-- Shows total number of bookings for this guest --}}
                        <td>{{this.bookings.length}}</td>

                        {{!-- Show dates from the most recent/first booking if it exists --}}
                        {{#if this.bookings.[0]}}
                            <td>{{this.bookings.[0].in}}</td>
                            <td>{{this.bookings.[0].out}}</td>
                        {{else}}
                            <td>N/A</td>
                            <td>N/A</td>
                        {{/if}}

                        <td>{{this.email}}</td>
                        <td>{{this.contact}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</main>