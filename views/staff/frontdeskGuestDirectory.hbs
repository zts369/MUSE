<script>
    function filterDirectory(query) {
        const rows = document.querySelectorAll('#guest-list .clickable-row');
        const q = query.toLowerCase().trim();
        let visibleCount = 0;

        rows.forEach(row => {
            const match = row.textContent.toLowerCase().includes(q);
            row.style.display = match ? '' : 'none';
            if (match) visibleCount++;
        });

        document.getElementById('no-dir-results').style.display = visibleCount === 0 ? 'block' : 'none';
    }

    document.addEventListener('DOMContentLoaded', () => {
        const input = document.getElementById('guest-search');
        const btn   = document.getElementById('guest-search-btn');

        input.addEventListener('input', () => filterDirectory(input.value));
        btn.addEventListener('click', () => filterDirectory(input.value));
    });
</script>
   
<main class="fd-main">
    <header class="content-header">
        <h2 id="tab-title" class="header-font">Guest Directory</h2>
        <div class="staff-info">Staff Access</div>
    </header>

    <div id="directory" class="tab-pane">
        <div class="guest-search-box">
            <input type="text" id="guest-search" placeholder="Search guests...">
            <button id="guest-search-btn" class="guest-search-btn">Search</button>
        </div>

        <p id="no-dir-results" style="display:none; color:#888; margin: 8px 0; font-family:'Montserrat';">No guests match your search.</p>
        <div class="fd-table-card">
            <table class="fd-data-table">
                <thead>
                    <tr>
                        <th>Guest Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Total Bookings</th>
                    </tr>
                </thead>
                <tbody id="guest-list">
                    {{#each guests}}
                        <tr class="clickable-row" data-guest="{{this.firstName}} {{this.lastName}}">
                            <td class="guest-name">{{this.firstName}} {{this.lastName}}</td>
                            <td>{{this.email}}</td>
                            <td>{{this.contact}}</td>
                            <td>{{this.bookings.length}}</td>
                        </tr>
                    {{/each}}
                </tbody>

            </table>
        </div>
    </div>
</main>