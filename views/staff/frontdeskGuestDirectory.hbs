<main class="fd-main">
    <header class="content-header">
        <h2 id="tab-title" class="header-font">Guest Directory</h2>
        <div class="staff-info">Staff Access</div>
    </header>

    <div id="directory" class="tab-pane">
        <div class="guest-search-box">
            <input type="text" id="guest-search" placeholder="Search guests...">
            <button id="guest-search-btn" class="guest-search-btn">Search</button>
        </div>

        <div class="fd-table-card">
            <table class="fd-data-table">
                <thead>
                    <tr>
                        <th>Guest Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Total Bookings</th>
                    </tr>
                </thead>
                <tbody id="guest-list">
                    {{#each guests}}
                        <tr class="clickable-row" data-guest="{{this.firstName}} {{this.lastName}}">
                            <td class="guest-name">{{this.firstName}} {{this.lastName}}</td>
                            <td>{{this.email}}</td>
                            <td>{{this.contact}}</td>
                            <td>{{this.bookings.length}}</td>
                        </tr>
                    {{/each}}
                </tbody>

            </table>
        </div>
    </div>
</main>