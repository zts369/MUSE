<script>
    function filterLogs(query) {
        const rows = document.querySelectorAll('#log-entry .log-entry');
        const q = query.toLowerCase().trim();
        let visibleCount = 0;

        rows.forEach(row => {
            const match = row.textContent.toLowerCase().includes(q);
            row.style.display = match ? '' : 'none';
            if (match) visibleCount++;
        });

        document.getElementById('no-log-results').style.display = visibleCount === 0 ? 'block' : 'none';
    }
</script>

<main class="fd-main">
    <header class="content-header">
        <h2 id="tab-title" class="header-font">View Reservations</h2>
        <div class="staff-info">Staff Access</div>
    </header>

    <div id="reservations" class="tab-pane">
        <div class="search-bar-wrapper">
            <input
                type="text"
                class="guest-search-input"
                placeholder="Search by guest, room, or action..."
                oninput="filterLogs(this.value)"
            >
        </div>
        <p id="no-log-results" style="display:none; color:#888; margin: 8px 0; font-family:'Montserrat';">No logs match your search.</p>
        <div class="fd-table-card">
            <table class="fd-data-table">
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>Guest</th>
                        <th>Room</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="log-entry">
                    {{#each logs}}
                        <tr class="log-entry">
                            <td class="log-time">
                                {{this.displayTime}} <span class="time-dim">{{this.displayClock}}</span>
                            </td>
                            <td><strong>{{this.guestName}}</strong></td>
                            <td>{{this.roomName}}</td>
                            <td><span class="log-badge badge-checkin">{{this.action}}</span></td>
                        </tr>
                    {{/each}}
                    
                </tbody>
            </table>
        </div>
    </div>
</main>

    