<main class="fd-main">
    <header class="content-header">
        <h2 id="tab-title" class="header-font">View Reservations</h2>
        <div class="staff-info">Staff Access</div>
    </header>

    <div id="reservations" class="tab-pane">
        <div class="fd-table-card">
            <table class="fd-data-table">
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>Guest</th>
                        <th>Room</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="log-entry">
                    {{#each logs}}
                        <tr class="log-entry">
                            <td class="log-time">{{}} <span class="time-dim">{{this.timestamp}}</span></td>
                            <td><strong>{{this.guestName}}</strong></td>
                            <td>{{this.roomName}}</td>
                            <td><span class="log-badge badge-checkin">{{this.status  }}</span></td>
                        </tr>
                    {{/each}}
                    
                </tbody>
            </table>
        </div>
    </div>
</main>

    