<main class="fd-content-section">
    <header class="content-header">
        <h2 id="booking-title" class="header-font">{{guest.firstName}} {{guest.lastName}}'s Booking</h2>
        <button onclick="window.history.back()" class="link-btn">← Back to View Reservations</button>
    </header>

    <div class="fd-table-card">
        <div class="guest-summary-box">
            <p><strong>Email:</strong> <span id="det-email">{{guest.email}}</span></p>
            <p><strong>Phone:</strong> <span id="det-phone">{{guest.contact}}</span></p>
        </div>
        
        <h4 class="section-label">Reservations</h4>
        <div id="booking-items-container">
            {{#if guest.bookings.length}}
                {{#each guest.bookings}}
                <div class="booking-item">
                    <div class="booking-flex">
                        <div class="booking-info">
                            <p><strong>Booking ID:</strong> <small>{{this.id}}</small></p>
                            <p><strong>Room:</strong> {{this.roomId}}</p>
                            <p><strong>Check-In:</strong> {{this.in}} | <strong>Check-Out:</strong> {{this.out}}</p>
                            <p><strong>Guests:</strong> {{this.adults}} Adults, {{this.children}} Children</p>
                            {{!-- Using a placeholder since total isn't in your JSON yet --}}
                            <p><strong>Total:</strong> ₱{{#if this.total}}{{this.total}}{{else}}0.00{{/if}}</p>
                        </div>
                        
                        <div class="status-control">
                            <label class="status-label">Status</label>
                            {{!-- Note: To save this to the DB, you'd need an actual <form> or a small script for the API call --}}
                            <select class="status-select status-{{toLowerCase this.status}}" onchange="updateStatusColor(this)">
                                <option value="Reserved" {{#if (eq this.status "Reserved")}}selected{{/if}}>Reserved</option>
                                <option value="Checked-In" {{#if (eq this.status "Checked-In")}}selected{{/if}}>Checked-In</option>
                                <option value="Checked-Out" {{#if (eq this.status "Checked-Out")}}selected{{/if}}>Checked-Out</option>
                                <option value="Cancelled" {{#if (eq this.status "Cancelled")}}selected{{/if}}>Cancelled</option>
                            </select>
                        </div>
                    </div>
                </div>
                {{/each}}
            {{else}}
                <p style="padding: 20px; text-align: center;">No active reservations for this guest.</p>
            {{/if}}
        </div>
    </div>
</main>

<script>
    // Just a small helper to keep your visual colors working when you click the dropdown
    function updateStatusColor(selectElement) {
        selectElement.classList.remove('status-reserved', 'status-checkedin', 'status-checkedout', 'status-cancelled');
        const val = selectElement.value.toLowerCase().replace('-', '');
        selectElement.classList.add(`status-${val}`);
    }
</script>