<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
    <title>Hotel Transylvania Booking</title>
</head>
<body class = "light-page">
    
    <main class="container" style = "background-color: #FFF7F0">
        <!-- navigation bar -->
        <div id="nav-placeholder" style = "padding-bottom: 10px;"></div>

        <hr style="height: 1px; border: none; background-color: #E8D1C5;">
        

        <!-- View Room / Suite Details-->

        <section id="{{room.id}}" class="room-details-page">
            <div class="detail-container text-center">
                <h1 class="room-main-title">{{room.roomName}}</h1>
                <div class="room-description">
                    <p class="lead-text">{{room.description}}</p>
                    <p>{{room.longerDescription}}</p>
                </div>
            </div>

            <div class="room-price-display text-center">
                <span class="amount">₱{{formatPrice rooms.price}}</span>
                <span class="per-night"> / Night</span>
            </div>

            <div class="room-buttons">
                <button class="room-book-button" onclick="location.href='booking.html'">Add Booking</button>
            </div>

            <section class="room-detail-gallery">
                <div class="specification-header">
                    <h3 class="section-subtitle text-center">Gallery</h3>
                </div>
                {{#each room.imageUrl}}
                    <div class="carousel-track">
                        <div class="room-card"><img src="{{this}}"></div>
                    </div>    
                {{/each}}                

            </section>

            <section class="specification-wrapper">
                <div class="specification-header">
                    <h3 class="section-subtitle text-center">Specifications</h3>
                </div>
                <div class="spec-flex-container">
                    <div class="spec-item">
                        <img src="img/sqm.png" alt="icon">
                        <span class="spec-label">ROOM SIZE</span>
                        <p>{{room.sqm}} SQM</p>
                    </div>
                    <div class="spec-item">
                        <img src="img/guests.png" alt="icon">
                        <span class="spec-label">MAX GUESTS</span>
                        <p>{{room.maxGuests}} Guests</p>
                    </div>
                    <div class="spec-item">
                        <img src="img/bed.png" alt="icon">
                        <span class="spec-label">NO. OF BEDS</span>
                        <p>{{room.beds}} King-size Bed</p>
                    </div>
                    <div class="spec-item">
                        <img src="img/bath.png" alt="icon">
                        <span class="spec-label">BATHROOM</span>
                        <p>{{room.bath}} Full Bath</p>
                    </div>
                </div>
            </section>

            <section class="detail-container">
                <div class="amenities-header">
                    <h3 class="section-subtitle text-center">Room Amenities</h3>
                </div>

                <div class="amenities-container">
                    <ul class="amenities-list">
                        {{#each room.amenities}}
                            <li>{{this}}</li>
                        {{/each}}
                    </ul>
                </div>
            </section>                
        </section>


        

        <!--FOOTER-->    
        <div id="footer-placeholder"></div>


        <script src="footerscript.js"></script>
        <script src="navscript.js"></script>
