<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    {{!-- Stylesheets --}}
    <link rel="stylesheet" href="/style/style.css">
    <link rel="stylesheet" href="/style/about.css">
    <link rel="stylesheet" href="/style/admin.css">
    <link rel="stylesheet" href="/style/amenities.css">
    <link rel="stylesheet" href="/style/booking.css">
    <link rel="stylesheet" href="/style/frontdesk-style.css">
    <link rel="stylesheet" href="/style/home.css">
    <link rel="stylesheet" href="/style/profile-style.css">
</head>
<body>

    {{!-- 1. HEADER LOGIC: Only show for Guests or Logged-out users --}}
    {{#unless (or (eq user.type "staff") (eq user.type "admin"))}}
        <header class="site-header">
            <div class="header-inner">
                <div class="logo">
                    <a class="logo-btn" href="/user/home">HOTEL TRANSYLVANIA</a>
                </div>
                <div class="header-right">
                    <div class="nav">
                        <a href="/user/home">Home</a>
                        <a href="/user/about">About Us</a>
                        <a href="/room">Rooms</a>
                        {{!-- <a href="/user/booking">Book</a> --}}
                        {{#if user}}
                            <a href="/logout">Logout</a>
                        {{else}}
                            <a href="/sign-up">Login</a>
                        {{/if}}
                    </div>
                    {{#if user}}
                        <a href="/user/profile/{{user.id}}" class="profile-icon-link" aria-label="Profile">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="profile-icon" fill="currentColor">
                                <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                            </svg>
                        </a>
                    {{/if}}
                </div>
            </div>
        </header>
    {{/unless}}

    {{!-- 2. MAIN BODY CONTENT --}}
    {{#if (eq user.type "staff")}}
        {{!-- Staff Dashboard Wrapper --}}
        <div class="fd-wrapper">
            <nav class="fd-sidebar">
                <div class="sidebar-header">
                    <h3 class="brand-title">Hotel Transylvania</h3>
                    <p class="brand-sub">Front Desk</p>
                </div>
                <ul class="fd-nav">
                    <li><a href="/staff/reservations" class="nav-item">View Reservations</a></li>
                    <li><a href="/staff/directory" class="nav-item">Guest Directory</a></li>
                    <li><a href="/staff/history" class="nav-item">History Logs</a></li>
                </ul>
                <div class="fd-sidebar-footer">
                    <a href="/logout" class="nav-item">Logout</a>
                </div>
            </nav>
            {{{body}}}
        </div>

    {{else if (eq user.type "admin")}}
        {{!-- Admin Dashboard Wrapper --}}
        <script src="/scripts/admin.js"></script>
        <div class="fd-wrapper">
            <nav class="fd-sidebar">
                <div class="sidebar-header">
                    <h3 class="brand-title">Hotel Transylvania</h3>
                    <p class="brand-sub">Admin Panel</p>
                </div>
                <ul class="fd-nav">
                    <li><a href="/admin/management" class="nav-item">Room Management</a></li>
                    <li><a href="/admin/reports" class="nav-item">Reports</a></li>
                </ul>
                <div class="fd-sidebar-footer">
                    <a href="/logout" class="nav-item">Logout</a>
                </div>
            </nav>
            {{{body}}}
        </div>

    {{else}}
        {{!-- Guest/Public Body --}}
        {{{body}}}
    {{/if}}

    {{!-- 3. FOOTER LOGIC: Only show for Guests or Logged-out users --}}
    {{#unless (or (eq user.type "staff") (eq user.type "admin"))}}
        <section class="footer-section">
            <div class="footer-body">
                <p>406 Mayon St, Santa Mesa Heights, Quezon City, Metro Manila <br> +63 917 420 6767 <br> testemail@gmail.com</p>
            </div>
            <div class="footer-title">
                <h4> Hotel </h4>
                <h1> Transylvania</h1>
            </div>
            <div class="footer-socials">
                <a href="#" aria-label="Facebook">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
                        <path d="M22 12c0-5.522-4.477-10-10-10S2 6.478 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.891h-2.33v6.987C18.343 21.128 22 16.991 22 12z"/>
                    </svg>
                </a>
                <a href="#" aria-label="TikTok">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
                        <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
                    </svg>
                </a>
                <a href="#" aria-label="Instagram">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.336 3.608 1.311.975.975 1.249 2.242 1.311 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.336 2.633-1.311 3.608-.975.975-2.242 1.249-3.608 1.311-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.336-3.608-1.311-.975-.975-1.249-2.242-1.311-3.608C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.062-1.366.336-2.633 1.311-3.608.975-.975 2.242-1.249 3.608-1.311C8.416 2.175 8.796 2.163 12 2.163zm0-2.163C8.741 0 8.332.014 7.052.072 5.197.157 3.355.673 2.014 2.014.673 3.355.157 5.197.072 7.052.014 8.332 0 8.741 0 12c0 3.259.014 3.668.072 4.948.085 1.855.601 3.697 1.942 5.038 1.341 1.341 3.183 1.857 5.038 1.942C8.332 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 1.855-.085 3.697-.601 5.038-1.942 1.341-1.341 1.857-3.183 1.942-5.038.058-1.28.072-1.689.072-4.948 0-3.259-.014-3.668-.072-4.948-.085-1.855-.601-3.697-1.942-5.038C20.645.673 18.803.157 16.948.072 15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zm0 10.162a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
                    </svg>
                </a>
                <a href="#" aria-label="X">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L2.25 2.25h6.988l4.265 5.636 4.741-5.636zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
                    </svg>
                </a>
            </div>
        </section>
        {{!-- Guest Scripts --}}
        <script src="/scripts/footerscript.js"></script>
        <script src="/scripts/carouselScript.js"></script>
        <script src="/scripts/amenities.js"></script>
    {{/unless}}

</body>
</html>