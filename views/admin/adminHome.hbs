<script src="adminHome.js"></script>
<body>
<main class="fd-main">
        <header class="content-header">
            <h2 class="header-font">Room Management</h2>
            <div class="staff-info">Admin Access</div>
        </header>

        <!-- Room Management Tab -->
        <div>
            <div class="fd-table-card">
                <button class="add-btn" onclick="openAddModal()">
                    <span>+</span> Add New Room
                </button>
                <table class="fd-data-table">
                    <thead>
                        <tr>
                            <th>Room Name</th>
                            <th>Price (Per Night)</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each rooms}}
                        <tr>
                            <td>{{this.roomName}}</td>
                            <td>{{formatPrice this.price}}</td>
                            <td><span class="tag success">
                                {{#if this.isAvailable)}}
                                    Available
                                {{else}}
                                    Unavailable
                                {{/if}}
                                </span></td>
                            <td>
                                <button class="action-btn edit-btn" onclick="openEditModal('Moonlight Room', 2000, 'Available', 'Spanning 60 sqm, the Moonlight Room offers a private haven...')">Edit</button>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <!-- Edit/Add Room Modal -->
    <div id="roomModal" class="modal-overlay">
        <div class="modal-content">
            <h3 id="modal-title" style="font-family: 'EB Garamond'; margin-top: 0; font-size: 1.5rem; color: #452829;">Edit Room</h3>
            <form onsubmit="event.preventDefault(); closeModal();">
                <div class="form-group">
                    <label>Room Name</label>
                    <input type="text" id="room-name" required placeholder="e.g. Moonlight Room">
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea id="room-desc" rows="4" placeholder="Enter room description..."></textarea>
                </div>
                <div class="form-group">
                    <label>Price per Night (₱)</label>
                    <input type="number" id="room-price" required placeholder="0.00">
                </div>
                <div class="form-group">
                    <label>Status</label>
                    <select id="room-status">
                        <option value="Available">Available</option>
                        <option value="Booked">Booked</option>
                        <option value="Maintenance">Maintenance</option>
                    </select>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn-cancel" onclick="closeModal()">Cancel</button>
                    <button type="submit" class="btn-save">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</body>