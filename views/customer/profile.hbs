<main class="prof-main">
    <h2 class="prof-page-title">Guest Profile</h2>

    <div class="prof-grid">
        <section class="prof-card prof-info-card">
            <h3 class="prof-card-header">Guest Info</h3>
            <div class="prof-info-group">
                <div class="prof-info-row">
                    <span class="prof-label">Full Name</span>
                    <span id="det-name" class="prof-value">{{user.firstName}} {{user.lastName}}</span>
                </div>
                <div class="prof-info-row">
                    <span class="prof-label">Phone</span>
                    <span id="det-phone" class="prof-value">{{user.contact}}</span>
                </div>
                <div class="prof-info-row">
                    <span class="prof-label">Email</span>
                    <span id="det-email" class="prof-value">{{user.email}}</span>
                </div>
            </div>
            <a href="#" class="prof-edit-link">Edit Profile</a>
        </section>

        <section class="prof-card prof-history-card">
            <h3 class="prof-card-header">Booking History</h3>
            <div id="prof-booking-wrapper">
                <table class="prof-history-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Room</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#if bookings.length}}
                            {{#each bookings}}
                            <tr>
                                <td>{{this.in}}</td>
                                <td style="text-transform: capitalize;">{{this.roomId}}</td>
                                <td>₱--.--</td>
                                <td>
                                    <span class="prof-status-pill {{this.status}}">
                                        {{this.status}}
                                    </span>
                                </td>
                            </tr>
                            {{/each}}
                        {{else}}
                            <tr>
                                <td colspan="4" style="text-align: center; padding: 20px;">No bookings found.</td>
                            </tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</main>


    <script>
        function renderPage() {
            const tableBody = document.getElementById('history-table-body');
            const tableElement = document.getElementById('history-table');
            const emptyState = document.getElementById('empty-state');
            
            // Set Profile Info
            document.getElementById('det-name').innerText = sampleGuest.name;
            document.getElementById('det-phone').innerText = sampleGuest.phone;
            document.getElementById('det-email').innerText = sampleGuest.email;

            // Render Table Rows
            tableBody.innerHTML = "";
            sampleGuest.bookings.forEach((booking) => {
                const tr = document.createElement('tr');
                
                let displayStatus = booking.status === "Checked-Out" ? "Completed" : booking.status;
                let actionHtml = "";
                
                if (booking.status === "Reserved") {
                    actionHtml = `<button class="cancel-btn" onclick="cancelBooking('${booking.id}')">Cancel</button>`;
                }

                tr.innerHTML = `
                    <td class="date-cell">${booking.in} -<br>${booking.out}</td>
                    <td>${booking.room}</td>
                    <td>₱${booking.total.toLocaleString()}</td>
                    <td>
                        <div class="status-cell">
                            <span class="status-text">${displayStatus}</span>
                            ${actionHtml}
                        </div>
                    </td>
                `;
                tableBody.appendChild(tr);
            });
        }

        function cancelBooking(bookingId) {
            if (confirm(`Are you sure you want to cancel booking ${bookingId}?`)) {
                // Remove the booking from our local sample object
                sampleGuest.bookings = sampleGuest.bookings.filter(b => b.id !== bookingId);
                alert("Booking cancelled successfully.");
                renderPage();
            }
        }

        // Initialize the page
        renderPage();
    </script>

