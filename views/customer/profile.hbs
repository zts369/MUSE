<main class="prof-main">
    <h2 class="prof-page-title">Guest Profile</h2>

    <div class="prof-grid">
        <section class="prof-card prof-info-card">
            <h3 class="prof-card-header">Guest Info</h3>
            <div class="prof-info-group">
                <div class="prof-info-row">
                    <span class="prof-label">Full Name</span>
                    <span id="det-name" class="prof-value">{{user.firstName}} {{user.lastName}}</span>
                </div>
                <div class="prof-info-row">
                    <span class="prof-label">Phone</span>
                    <span id="det-phone" class="prof-value">{{user.contact}}</span>
                </div>
                <div class="prof-info-row">
                    <span class="prof-label">Email</span>
                    <span id="det-email" class="prof-value">{{user.email}}</span>
                </div>
            </div>
            <button class="prof-edit-link" onclick="openEditProfile()">Edit Profile</button>
        </section>

        <section class="prof-card prof-history-card">
            <h3 class="prof-card-header">Booking History</h3>
            <div id="prof-booking-wrapper">
                <table class="prof-history-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Room</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#if bookings.length}}
                            {{#each bookings}}
                            <tr>
                                <td>{{this.in}}</td>
                                <td style="text-transform: capitalize;">{{this.roomId}}</td>
                                <td>₱{{formatPrice this.price}}</td>
                                <td>
                                    <span class="prof-status-pill {{this.status}}">
                                        {{this.status}}
                                    </span>
                                </td>
                            </tr>
                            {{/each}}
                        {{else}}
                            <tr>
                                <td colspan="4" style="text-align: center; padding: 20px;">No bookings found.</td>
                            </tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</main>


<!-- Edit Profile Modal -->
<div id="editProfileModal" class="prof-modal-overlay">
    <div class="prof-modal-content">
        <h3 class="prof-modal-title">Edit Profile</h3>
        <form method="POST" action="/user/profile/{{user.id}}/edit" onsubmit="return validateEditForm()">
            <div class="prof-form-row">
                <div class="prof-form-group">
                    <label>First Name</label>
                    <input type="text" name="firstName" value="{{user.firstName}}" required>
                </div>
                <div class="prof-form-group">
                    <label>Last Name</label>
                    <input type="text" name="lastName" value="{{user.lastName}}" required>
                </div>
            </div>
            <div class="prof-form-group">
                <label>Email</label>
                <input type="email" name="email" value="{{user.email}}" required>
            </div>
            <div class="prof-form-group">
                <label>Phone</label>
                <input type="text" name="contact" value="{{user.contact}}" required maxlength="11">
            </div>
            <hr style="border-color:#E8D1C5; margin: 16px 0;">
            <p style="font-size:0.8rem; color:#8d6e63; margin-bottom:12px;">Leave password fields blank to keep your current password.</p>
            <div class="prof-form-group">
                <label>New Password</label>
                <input type="password" name="password" id="edit-password" placeholder="Enter new password">
            </div>
            <div class="prof-form-group">
                <label>Confirm New Password</label>
                <input type="password" name="confirmPassword" id="edit-confirm-password" placeholder="Confirm new password">
            </div>
            <p id="edit-pw-error" style="color:#e23e2c; font-size:0.85rem; display:none;">Passwords do not match.</p>
            <div class="prof-modal-actions">
                <button type="button" class="prof-btn-cancel" onclick="closeEditProfile()">Cancel</button>
                <button type="submit" class="prof-btn-save">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openEditProfile() {
        document.getElementById('editProfileModal').style.display = 'flex';
    }
    function closeEditProfile() {
        document.getElementById('editProfileModal').style.display = 'none';
    }
    function validateEditForm() {
        const pw  = document.getElementById('edit-password').value;
        const cpw = document.getElementById('edit-confirm-password').value;
        const err = document.getElementById('edit-pw-error');
        if (pw && pw !== cpw) {
            err.style.display = 'block';
            return false;
        }
        err.style.display = 'none';
        return true;
    }
    window.addEventListener('click', (e) => {
        const modal = document.getElementById('editProfileModal');
        if (e.target === modal) closeEditProfile();
    });
</script>